<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Calculo_ductos_winUi_3.Views.CalculateIndirectsOthersSubview"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Calculo_ductos_winUi_3.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid x:Name="LeftGrid"
      Grid.Column="0"
      Grid.Row="1">
        <Grid 
        Grid.Row="1" 
        Grid.Column="0" CornerRadius="8" 
        Margin="36,32,16,36"
        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
            </Grid.RowDefinitions>

            <Grid
                x:Name="DataCard"
                Margin="16,16,16,36"
                CornerRadius="8" 
   
                >
                <Grid.ColumnDefinitions>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"></RowDefinition>
                    <RowDefinition Height="*"></RowDefinition>
                    <RowDefinition Height="*"></RowDefinition>
                    <RowDefinition Height="*"></RowDefinition>
                    <RowDefinition Height="*"></RowDefinition>
                </Grid.RowDefinitions>
                <StackPanel 
                Orientation="Vertical" 
                Grid.Column="0" 
                Grid.Row="1" 
                Grid.ColumnSpan="2"
                Padding="0,8,0,0"
                Margin="8"
                Height="Auto">
                    <TextBlock x:Name="lblViatico" Margin="0,0,0,8" >Viático</TextBlock>
                    <ComboBox x:Name="cbxViatico"
                        ItemsSource="{x:Bind stateApp.IndirectsVM.AvailableIndirects, Mode=OneWay}"
                        SelectedItem="{x:Bind stateApp.IndirectsVM.SelectedIndirect, Mode=TwoWay}" 
                        DisplayMemberPath="Concept">
                    </ComboBox>
                </StackPanel>
                <StackPanel 
                    Orientation="Vertical" 
                    Grid.Column="0" 
                    Grid.Row="2" 
                    Grid.ColumnSpan="2"
                    Padding="0,8,0,0"
                    Margin="10"
                    Height="Auto">

                    <TextBlock x:Name="lblPrecio" Margin="0,0,0,8">Precio</TextBlock>

                    <TextBox 
                        x:Name="txtNombreEjecutivo" 
                        Text="{x:Bind stateApp.IndirectsVM.selectedUnitCost, Mode=TwoWay}"
                        Height="30"></TextBox>
                </StackPanel>
                
                <StackPanel 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Center"
                    Grid.Column="0" 
                    Grid.Row="4" 
                    Grid.ColumnSpan="2"
                    Margin="10"
                    Height="Auto">

                    <Button x:Name="btnAgregarMP" Margin="8" 
                            Click="AddIndirect_Click">Agregar</Button>
                    <Button x:Name="btnCalcularMP" Click="CalculateIndirects_Click" Margin="8">Calcular</Button>

                </StackPanel>
            </Grid>


        </Grid>
    </Grid>
</Page>
